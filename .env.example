# ─────────────────────────────────────────────────────────────────────────────
# Haptiq SkillSync — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
#
# These variables are inlined into the JavaScript bundle by Vite at build time
# (via import.meta.env.*). They are NOT runtime container environment variables.
# For deployments, supply them as --build-arg values to `docker build`.
#
# For GitHub Actions CD, add them as repository secrets:
#   Settings > Secrets and variables > Actions > New repository secret
# ─────────────────────────────────────────────────────────────────────────────

# ─── Persistence Layer ───────────────────────────────────────────────────────
# Controls which database backend the app uses.
# Allowed values: "supabase" (default) | "mysql"
# See docs/PERSISTENCY_SWITCH.md for full setup instructions.
VITE_DB_PROVIDER=supabase

# ─── Supabase (required when VITE_DB_PROVIDER=supabase) ──────────────────────

# Supabase project URL
# Found in: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anonymous (public) key — safe to expose in client-side code
# Found in: Supabase Dashboard > Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<your-anon-key>

# ─── MySQL (required when VITE_DB_PROVIDER=mysql) ────────────────────────────

# Base URL of your MySQL REST API server (no trailing slash).
# Example: http://localhost:3001  or  https://api.yourcompany.com
# The server must implement the contract described in docs/PERSISTENCY_SWITCH.md
VITE_MYSQL_API_URL=http://localhost:3001
